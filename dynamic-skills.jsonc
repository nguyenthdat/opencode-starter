{
  // =========================================================================
  // Dynamic Skills Plugin Configuration
  // =========================================================================
  // This file controls where the dynamic-skills plugin searches for skills.
  // Skills follow the standard OpenCode format: <skill-name>/SKILL.md
  // with an optional references/ folder.
  //
  // Priority order (highest to lowest):
  //   1. Project-local    (.opencode/skills)
  //   2. Harness team     (harness/*/skills)
  //   3. Vendor           (.opencode/vendor/*/skills)
  //   4. Shared/global    (absolute paths, e.g. ~/opencode-shared/skills)
  // =========================================================================

  // $schema: "https://opencode.ai/dynamic-skills.schema.json",

  // Array of skill search paths.
  // Supports:
  //   - Relative paths (resolved from project root)
  //   - Glob patterns for team/vendor directories
  //   - Home directory expansion (~/)
  //   - Absolute paths
  "searchPaths": [".opencode/skills", "harness/*/skills", ".opencode/vendor/*/skills"],

  // Cache time-to-live in seconds. Discovery results are cached
  // for this duration. Use skills_refresh to force re-scan.
  "cacheTTL": 300,

  // When true, absolute paths (starting with /) are allowed in searchPaths.
  // When false, absolute paths are rejected for safety.
  "allowAbsolutePaths": false,

  // When true, enables verbose debug logging for all skill operations.
  // Override per-call with the `debug` argument on any tool.
  "debug": false,

  // Maximum size (in bytes) of a SKILL.md file to load.
  // Files larger than this will be truncated with a warning.
  "maxSkillFileSize": 1048576,
}
