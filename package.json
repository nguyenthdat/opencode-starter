{
  "name": "@nguyenthdat/opencode-developer",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "bun test",
    "test:native": "bun run native:build && bun test ./tests/native-diagnostics.integration.ts",
    "native:build": "cargo build -p opencode-native-diagnostics",
    "native:build:release": "cargo build -p opencode-native-diagnostics --release",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo test --workspace --all-features",
    "check": "bun run typecheck && bun test && bun run check:rust && bun run test:native"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.18.1",
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": { "@types/bun": "1.3.14", "typescript": "^5.9.3" }
}
