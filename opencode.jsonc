{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "subagent_depth": 2,
  "formatter": true,
  "provider": {
    "openai": { "options": { "headerTimeout": 99999, "timeout": 999999, "chunkTimeout": 99999 } },
  },
  "instructions": [
    "AGENTS.md",
    "~/.config/opencode/instructions/*",
    "~/.config/opencode/AGENTS.md",
    "~/.opencode/instructions/*",
    "~/.opencode/AGENTS.md",
    ".opencode/instructions/*",
  ],
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "list": "allow",
    "skill": "allow",
    "read": "allow",
    "task": "deny",
    "doom_loop": "deny",
    "external_directory": "ask",
  },
  "agent": {
    "explore": {
      "steps": 15,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git diff*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "tree*": "allow",
        },
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "external_directory": "deny",
      },
    },
    "build": { "permission": { "doom_loop": "deny", "task": { "*": "allow", "build": "deny" } } },
    "general": { "permission": { "task": "deny", "doom_loop": "deny" } },
    "title": { "model": "opencode/deepseek-v4-flash-free", "variant": "none" },
    "compaction": { "temperature": 0, "prompt": "{file:./prompts/compaction.txt}" },
    "summary": { "model": "opencode/deepseek-v4-flash-free", "variant": "none" },
  },
  "compaction": { "auto": true, "prune": true, "reserved": 20000 },
  "experimental": { "continue_loop_on_deny": false, "mcp_timeout": 30000 },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth",
    "@nguyenthdat/opencode-xberg",
    "github:nguyenthdat/opencode-crawlberg",
    "github:nguyenthdat/opencode-html-to-markdown",
    "github:nguyenthdat/opencode-tree-sitter-language-pack",
  ],
  "lsp": true,
  "mcp": {
    // @mcp-group core | Core MCP services
    "codebase-memory": { "enabled": true, "type": "local", "command": ["codebase-memory-mcp"] },
    "git": { "enabled": true, "type": "local", "command": ["uvx", "mcp-server-git"] },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" },
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer {env:CONTEXT7_API_KEY}" },
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "headers": { "x-api-key": "{env:EXA_API_KEY}" },
    },
    "cloakbrowser": {
      "enabled": true,
      "type": "local",
      "command": ["bunx", "-y", "cloakbrowser-mcp@latest"],
      "environment": {
        "PLAYWRIGHT_MCP_OUTPUT_DIR": ".cloakbrowser-artifacts",
        "PLAYWRIGHT_MCP_HEADLESS": "true",
      },
    },
  },
}
