{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [".opencode/instructions/*", "~/.config/opencode/instructions/*"],
  "formatter": true,
  // Fish shell is the default. Set shell to /bin/bash to revert.
  // Plugin at plugins/fish-shell.ts handles Fish-aware command wrapping and LLM instruction updates.
  "shell": "fish",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "list": "allow",
    "skill": "allow",
    "read": "allow",
    "task": "allow",
    "external_directory": "ask",
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth",
    "@xberg-io/opencode-xberg",
    "@xberg-io/opencode-crawlberg",
    "@xberg-io/opencode-html-to-markdown",
    "@xberg-io/opencode-tree-sitter-language-pack",
  ],
  "lsp": true,
  "mcp": {
    "qdrant": {
      "enabled": true,
      "type": "local",
      "command": ["uvx", "mcp-server-qdrant"],
      "environment": {
        "QDRANT_URL": "http://localhost:6333",
        "EMBEDDING_MODEL": "intfloat/multilingual-e5-large",
        "TOOL_STORE_DESCRIPTION": "Store durable project memory: fixed errors with root cause and solution, user-requested changes and their rationale, confirmed bug fixes, implementation decisions, architectural rationale, constraints, conventions, reusable workflows, resolved blockers, and lessons learned. Automatically store after every meaningful task completion, error fix, or user-directed change. Never store secrets, credentials, temporary logs, raw conversations, or unverified guesses.",
        "TOOL_FIND_DESCRIPTION": "Search long-term project memory before starting any task. Find architectural decisions, constraints, conventions, previous errors and their fixes, known issues with workarounds, user-requested changes history, reusable implementation patterns, and task-relevant context. Always search first to avoid repeating past mistakes or re-solving solved problems.",
      },
    },
    "memory": { "enabled": true, "type": "local", "command": ["bunx", "-y", "@modelcontextprotocol/server-memory"] },
    "git": { "enabled": true, "command": ["uvx", "mcp-server-git"], "type": "local" },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" },
    },
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command": ["bunx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
    },
    "filesystem": { "type": "local", "command": ["bunx", "-y", "@modelcontextprotocol/server-filesystem", "."] },
    "token-optimizer": { "type": "local", "command": ["bunx", "-y", "token-optimizer-mcp"] },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer {env:CONTEXT7_API_KEY}" },
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "headers": { "x-api-key": "{env:EXA_API_KEY}" },
    },
    "everything": { "enabled": true, "type": "local", "command": ["bunx", "-y", "@modelcontextprotocol/server-everything"] },
    "time": { "enabled": true, "type": "local", "command": ["uvx", "mcp-server-time"] },
    "cloakbrowser": {
      "type": "local",
      "command": ["bunx", "-y", "cloakbrowser-mcp@latest"],
      "environment": { "PLAYWRIGHT_MCP_OUTPUT_DIR": ".cloakbrowser-artifacts", "PLAYWRIGHT_MCP_HEADLESS": "true" },
    },
  },
}
