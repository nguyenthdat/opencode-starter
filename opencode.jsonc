  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "list": "allow",
    "skill": "allow",
    "read": "allow",
    "task": "deny",
    "doom_loop": "deny",
    "external_directory": "ask",
  },
  "agent": {
    "build": {
      "steps": 32,
      "permission": {
        "doom_loop": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "general": "allow",
          "plan": "allow",
          "search": "allow",
          "research": "allow",
          "research-web": "allow",
          "research-academic": "allow",
          "research-community": "allow",
          "research-validator": "allow",
          "research-synthesizer": "allow",
          "skill-creator-grader": "allow",
          "skill-creator-comparator": "allow",
          "skill-creator-analyzer": "allow",
        },
      },
    },
    "general": { "steps": 14, "permission": { "task": "deny", "doom_loop": "deny" } },
    "explore": { "steps": 10, "permission": { "task": "deny", "doom_loop": "deny" } },
  },
  "compaction": { "auto": true, "prune": true, "tail_turns": 6 },
  "tool_output": { "max_lines": 1000, "max_bytes": 32768 },
  "experimental": { "continue_loop_on_deny": false, "mcp_timeout": 30000 },
  "plugin": ["@ex-machina/opencode-anthropic-auth", "oc-codex-multi-auth"],
  "lsp": true,
  "mcp": {
    "codebase-memory": { "enabled": true, "type": "local", "command": ["codebase-memory-mcp"] },
    "agentic-memory": {
      "enabled": true,
      "type": "local",
      "command": ["agentic-memory-mcp", "serve"],
    },
    "git": { "enabled": true, "command": ["uvx", "mcp-server-git"], "type": "local" },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" },
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer {env:CONTEXT7_API_KEY}" },
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "headers": { "x-api-key": "{env:EXA_API_KEY}" },
    },
    "time": { "enabled": true, "type": "local", "command": ["uvx", "mcp-server-time"] },
    "cloakbrowser": {
      "type": "local",
      "command": ["bunx", "-y", "cloakbrowser-mcp@latest"],
      "environment": {
        "PLAYWRIGHT_MCP_OUTPUT_DIR": ".cloakbrowser-artifacts",
        "PLAYWRIGHT_MCP_HEADLESS": "true",
      },
    },
  },
}
